NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Passcode lock (server-only -- no NEXT_PUBLIC_ prefix, so these never ship
# to the browser). Defaults to 275688 if you don't set YOUCARD_PIN at all.
YOUCARD_PIN=275688
YOUCARD_PIN_SECRET=change-this-to-any-random-string
